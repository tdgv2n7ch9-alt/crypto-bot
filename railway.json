{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "*.py",
      "requirements.txt",
      "Dockerfile",
      "railway.json",
      "backtest/**",
      "tests/**",
      "patches/**"
    ]
  },
  "deploy": {
    "startCommand": "python bot.py",
    "restartPolicyType": "ON_FAILURE"
  }
}
